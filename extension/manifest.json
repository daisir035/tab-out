{
  "manifest_version": 3,
  "name": "Tab Out",
  "version": "1.1.0",
  "description": "Keep tabs on your tabs and ChiefDelphi topics. New tab page that groups open tabs and tracks followed forum posts.",
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": ["https://www.chiefdelphi.com/*"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.chiefdelphi.com/t/*"],
      "js": ["content-script.js"],
      "css": ["content-script.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
